{
  "name": "@iqkv/sample-lorem",
  "version": "0.25.0",
  "private": true,
  "description": "Provide an optional Git commit hooks.",
  "license": "Apache-2.0",
  "author": "Dima Denisenko",
  "type": "module",
  "scripts": {
    "formatter:check": "oxfmt --check",
    "formatter:write": "oxfmt --write",
    "lint": "pnpm lint:stylelint && pnpm formatter:check",
    "lint:stylelint": "stylelint \"**/*.css\" --aei",
    "node_modules:clear": "rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "cz-conventional-changelog": "^3.3.0",
    "glob": "^13.0.6",
    "husky": "9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "prettier-plugin-java": "2.8.1",
    "release-it": "^19.2.4",
    "release-it-pnpm": "^4.6.6",
    "sort-package-json": "^3.6.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "tsdown": "^0.21.6"
  },
  "lint-staged": {
    "*": [
      "pnpm formatter:check"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.15.0"
  }
}
